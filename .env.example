# =====================================================================
# bernard (plugin Claude Code) — Variables d'environnement
# =====================================================================
# Copier ce fichier en .env (localement, gitignore) ou declarer dans
# ~/.claude/settings.json de Claude Code. Les placeholders ${...} dans
# .mcp.json et dans prompts/*.md sont remplaces par les valeurs d'ici.
# =====================================================================

# ---------------------------------------------------------------------
# MCP agent-memory (Soul / Heart / Memory / Knowledge / Scratchpad)
# ---------------------------------------------------------------------

# Endpoint HTTP du serveur MCP agent-memory.
# Production (Fly.io) : https://agent-memory-mcp.fly.dev
# Local dev            : http://localhost:3001
AGENT_MEMORY_URL=https://agent-memory-mcp.fly.dev

# Bearer token d'authentification agent-memory.
# Generer en local : openssl rand -hex 32
# Prod : recuperer depuis le dashboard Fly.io / 1Password
# Utilise par les prompts routines (bernard-daily-scan, nova, mika, iris, laure, casey).
AGENT_MEMORY_TOKEN=

# ---------------------------------------------------------------------
# ClickUp (MCP + chat channel utilises dans les routines)
# ---------------------------------------------------------------------

CLICKUP_WORKSPACE_ID=
CLICKUP_API_TOKEN=
# Channel chat ClickUp pour les posts BERNARD/CASEY (ID court "xxxxx-xxx")
CLICKUP_CHAT_CHANNEL=

# ---------------------------------------------------------------------
# Telegram (bot + push endpoint Bernard)
# ---------------------------------------------------------------------

# Token du bot Telegram (format: 12345:AA...). Fallback direct pour sendMessage.
TELEGRAM_BOT_TOKEN=
# Chat ID destinataire des notifications (user ID numerique).
TELEGRAM_CHAT_ID=
# Bearer token du endpoint POST /push du bernard-telegram-bot Fly.io.
# (Value de BERNARD_PUSH_TOKEN cote serveur bot.)
TELEGRAM_PUSH_TOKEN=

# ---------------------------------------------------------------------
# Claude.ai (sync routines via API triggers)
# ---------------------------------------------------------------------

# sessionKey cookie claude.ai (DevTools > Application > Cookies > claude.ai).
# Commence par sk-ant-sid01-...
# Requis pour `node scripts/sync-routines.mjs` (sauf DRY_RUN=1).
CLAUDE_SESSION_TOKEN=

# ---------------------------------------------------------------------
# Optionnel — Google Workspace CLI (briefing matin : emails, agenda)
# ---------------------------------------------------------------------

GWS_CLI_PATH=/usr/local/bin/gws
